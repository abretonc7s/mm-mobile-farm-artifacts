{
  "schema_version": 1,
  "title": "TAT-3398 Auto Close RoE sign toggle",
  "description": "Proves the RoE sign badge on the Auto Close (PerpsTPSL) sheet renders defaults (+ TP / - SL), toggles the sign while keeping the value and recomputing the trigger (positive <-> negative return) on tap, flips to match a preset chip's sign, applies a negative sign to the take-profit trigger, and resets to defaults when the sheet is reopened.",
  "proofTargets": [
    {
      "id": "ac1",
      "claim": "On first render the TP RoE badge shows + and the SL RoE badge shows -"
    },
    {
      "id": "ac2",
      "claim": "Tapping the + TP badge changes it to - while keeping the value and recomputing the trigger below entry"
    },
    {
      "id": "ac3",
      "claim": "Tapping the - TP badge changes it back to + while keeping the value"
    },
    {
      "id": "ac4",
      "claim": "Tapping the - SL badge changes it to + while keeping the value and recomputing the trigger above entry"
    },
    {
      "id": "ac5",
      "claim": "Tapping a + preset chip while the TP badge is - flips the badge back to +"
    },
    {
      "id": "ac6",
      "claim": "A take-profit RoE entered with a - sign produces a below-entry (negative RoE) trigger price"
    },
    {
      "id": "ac7",
      "claim": "Reopening the sheet resets the badges to + TP / - SL"
    }
  ],
  "validate": {
    "workflow": {
      "pre_conditions": [],
      "entry": "wallet-unlock",
      "nodes": {
