          "intent": "Open the Auto Close sheet",
          "phase": "nav"
        },
        "wait-sheet": {
          "action": "ui.wait_for",
          "test_id": "perps-tpsl-bottomsheet",
          "expected": "present",
          "visibility": "viewport",
          "timeout_ms": 20000,
          "next": "ac1-tp-badge",
          "intent": "Auto Close sheet is visible",
