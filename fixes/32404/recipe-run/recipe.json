          "phase": "setup"
        },
        "navigate-market": {
          "action": "ui.navigate",
          "page": "perps-market",
          "market": "ETH",
          "timeout_ms": 45000,
          "next": "wait-long",
          "intent": "Open the ETH Perps market",
          "phase": "nav"
        },
        "wait-long": {
          "action": "ui.wait_for",
          "test_id": "perps-market-details-long-button",
          "expected": "present",
          "timeout_ms": 45000,
          "next": "press-long",
          "intent": "Wait for the Long entry button",
          "phase": "nav"
        },
        "press-long": {
          "action": "ui.press",
          "test_id": "perps-market-details-long-button",
          "timeout_ms": 20000,
          "next": "wait-tpsl-row",
          "intent": "Open the order view (long)",
          "phase": "nav"
        },
        "wait-tpsl-row": {
          "action": "ui.wait_for",
          "test_id": "perps-order-view-stop-loss-button",
