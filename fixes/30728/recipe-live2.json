{
  "schema_version": 1,
  "title": "Related Markets rail - scrolled screenshot",
  "validate": {
    "workflow": {
      "entry": "open-eth-market",
      "nodes": {
        "open-eth-market": {
          "action": "ui.navigate",
          "page": "perps-market",
          "market": "ETH",
          "intent": "Open the ETH perps market detail screen",
          "next": "wait-related-rail"
        },
        "wait-related-rail": {
          "action": "ui.wait_for",
          "test_id": "perps-related-markets-rail",
          "expected": "present",
          "timeout_ms": 20000,
          "intent": "Wait for the Related markets rail to mount",
          "next": "scroll-1"
        },
        "scroll-1": {
          "action": "ui.scroll",
          "test_id": "perps-market-details-scroll-view",
          "delta_y": 900,
          "intent": "Scroll the market detail container down toward the rail",
          "next": "scroll-2"
        },
        "scroll-2": {
          "action": "ui.scroll",
          "test_id": "perps-market-details-scroll-view",
          "delta_y": 900,
          "intent": "Continue scrolling toward the rail",
          "next": "settle"
        },
        "settle": {
          "action": "wait",
          "ms": 1200,
          "intent": "Let the scroll settle before capturing",
          "next": "screenshot-rail"
        },
        "screenshot-rail": {
          "action": "ui.screenshot",
          "path": "screenshots/related-markets-rail-visible.png",
          "intent": "Capture the Related markets rail in view",
          "next": "done"
        },
        "done": {
          "action": "end",
          "status": "pass",
          "intent": "Finish: rail captured in view"
        }
      }
    }
  }
}
